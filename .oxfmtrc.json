{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/.alchemy",
    "**/.codex",
    "**/.expo",
    "**/.next",
    "**/.nuxt",
    "**/.source",
    "**/.svelte-kit",
    "**/.turbo",
    "**/.vscode",
    "**/.wrangler",
    "**/.zed",
    "**/convex/_generated",
    "**/dev-dist",
    "**/dist",
    "**/routeTree.gen.ts",
    "**/src-tauri",
    "**/wrangler.jsonc",
    "apps/native/android",
    "apps/native/ios"
  ],
  "jsxSingleQuote": false,
  "printWidth": 80,
  "quoteProps": "as-needed",
  "semi": false,
  "singleAttributePerLine": false,
  "singleQuote": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
